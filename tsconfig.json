{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["node"],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noEmit": true,
		"skipLibCheck": true
	},
	"include": ["src", "eslint.config.ts", "worker-configuration.d.ts"],
	"exclude": ["node_modules", "cmd", "dist"]
}
